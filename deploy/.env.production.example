# ============================================================
# NOVAPLAY Minigame Hub - Production Environment Variables
# Copy this file to /var/www/minigame-hub/.env and fill in values
# ============================================================

# ── Database (MySQL 5.7) ─────────────────────────────────
DATABASE_URL=mysql://minigame_user:YOUR_DB_PASSWORD@127.0.0.1:3306/minigame_hub

# ── App ──────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ── Auth ─────────────────────────────────────────────────
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_STRING

# ── Manus OAuth (if using Manus login) ───────────────────
VITE_APP_ID=your_manus_app_id
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://login.manus.im
OWNER_OPEN_ID=your_owner_open_id
OWNER_NAME=Admin

# ── Built-in APIs ─────────────────────────────────────────
BUILT_IN_FORGE_API_URL=https://api.manus.im
BUILT_IN_FORGE_API_KEY=your_forge_api_key
VITE_FRONTEND_FORGE_API_KEY=your_frontend_forge_key
VITE_FRONTEND_FORGE_API_URL=https://api.manus.im

# ── Analytics (optional) ──────────────────────────────────
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
